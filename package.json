{
  "name": "pickle-rick-codex",
  "version": "0.2.17-beta.1",
  "description": "Pickle Rick autonomous engineering lifecycle — Codex CLI native port",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm --prefix extension test",
    "test:installed": "npm --prefix extension run test:runtime",
    "release:gate": "npm --prefix extension run typecheck && npm --prefix extension run lint && npm test",
    "smoke": "node ./extension/bin/status.js --help >/dev/null",
    "install:local": "bash install.sh",
    "validate:codex": "node ./extension/bin/validate-codex.js",
    "check:readiness": "node ./extension/bin/check-readiness.js"
  },
  "license": "MIT"
}
