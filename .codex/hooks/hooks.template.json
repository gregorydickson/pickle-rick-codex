{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.codex/pickle-rick/bin/session-start.js",
            "timeout": 5,
            "statusMessage": "Initializing Pickle Rick session..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.codex/pickle-rick/bin/stop-hook.js",
            "timeout": 10,
            "statusMessage": "Running Pickle Rick stop hook..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^shell$",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.codex/pickle-rick/bin/log-commit.js",
            "timeout": 5,
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(apply_patch|shell)$",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.codex/pickle-rick/bin/config-protection.js",
            "timeout": 5,
            "statusMessage": "Validating file safety..."
          }
        ]
      }
    ]
  }
}
